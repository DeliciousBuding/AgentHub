#!/bin/bash
# AgentHub commit-msg hook — enforce Conventional Commits
# Rule: type(scope): English description
# Scope is optional. Description lowercase, no trailing period.

COMMIT_MSG=$(cat "$1" | tr -d '\r')
SUBJECT=$(echo "$COMMIT_MSG" | head -1)

# === 1. Allowed types ===
TYPES="init|feat|fix|docs|refactor|chore|test|perf|ci|revert"

# === 2. Pattern: type(scope): description  or  type: description ===
PATTERN="^($TYPES)(\([a-z0-9._-]+\))?: [a-z].+"

if ! echo "$SUBJECT" | grep -qE "$PATTERN"; then
    echo ""
    echo "  Invalid commit message format."
    echo ""
    echo "  Required: type(scope): description"
    echo "  Examples:"
    echo "    docs: add architecture diagrams"
    echo "    feat(edge): implement websocket hub"
    echo "    fix(runner): handle subprocess timeout"
    echo "    refactor: reorganize reference docs"
    echo ""
    echo "  Allowed types: $TYPES"
    echo "  Scope is optional, lowercase alphanumeric + . _ -"
    echo "  Description: lowercase English, no trailing period"
    echo ""
    exit 1
fi

# === 3. Check subject line length (72 chars max) ===
LEN=$(echo "$SUBJECT" | wc -c)
if [ $LEN -gt 72 ]; then
    echo ""
    echo "  Subject line too long ($LEN > 72 chars)."
    echo "  Keep it concise — details go in the body."
    echo ""
    exit 1
fi

# === 4. No trailing period ===
if echo "$SUBJECT" | grep -qE '\.$'; then
    echo ""
    echo "  Remove trailing period from subject line."
    echo ""
    exit 1
fi

exit 0
