# AgentHub 环境配置示例
# 复制为 .env 并填入实际值

# ── Edge Server ──────────────────────────
# Claude Code CLI 路径（Windows 示例）
# CLAUDE_CODE_PATH=C:\Users\<user>\.local\bin\claude.exe
# macOS/Linux 示例
# CLAUDE_CODE_PATH=/usr/local/bin/claude

# OpenCode CLI 路径
# OPENCODE_PATH=opencode

# Codex CLI 路径
# CODEX_PATH=codex

# ── Hub Server ──────────────────────────
# HUB_DATABASE_URL=postgres://user:pass@localhost:5432/agenthub
# HUB_REDIS_URL=redis://localhost:6379
# HUB_JWT_SECRET=change-me-in-production

# ── Desktop ─────────────────────────────
# VITE_EDGE_URL=http://127.0.0.1:3210
# VITE_HUB_URL=http://127.0.0.1:4210
