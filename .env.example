# AgentHub 环境配置示例
# 复制为 .env 并填入实际值
#   cp .env.example .env

# ─────────────────────────────────────────────
# Docker Compose 本地开发环境
# ─────────────────────────────────────────────

# ── PostgreSQL 16 ───────────────────────────
AGENTHUB_DB_HOST=localhost
AGENTHUB_DB_PORT=5432
AGENTHUB_DB_USER=agenthub
AGENTHUB_DB_PASSWORD=dev_password
AGENTHUB_DB_NAME=agenthub

# ── Redis 7 ─────────────────────────────────
AGENTHUB_REDIS_HOST=localhost
AGENTHUB_REDIS_PORT=6379
AGENTHUB_REDIS_PASSWORD=

# ── JWT ─────────────────────────────────────
# 开发环境至少 32 字符；生产环境用随机长字符串。
# 示例：openssl rand -hex 32
AGENTHUB_JWT_SECRET=dev-secret-change-in-production-min-length-32
AGENTHUB_JWT_ACCESS_TTL=15m
AGENTHUB_JWT_REFRESH_TTL=720h

# ── Hub Server ──────────────────────────────
AGENTHUB_SERVER_PORT=8080
AGENTHUB_SERVER_LOG_LEVEL=debug
AGENTHUB_SERVER_ADMIN_PORT=6060
AGENTHUB_UPLOAD_DIR=./uploads
AGENTHUB_UPLOAD_MAX_SIZE=10485760

# ── Pprof 管理端 (Basic Auth) ───────────────
# AGENTHUB_PPROF_USER=admin
# AGENTHUB_PPROF_PASS=

# ─────────────────────────────────────────────
# 本地裸机开发（不使用 Docker Compose 时）
# ─────────────────────────────────────────────

# ── Edge Server ─────────────────────────────
# Claude Code CLI 路径（Windows 示例）
# CLAUDE_CODE_PATH=C:\Users\<user>\.local\bin\claude.exe
# macOS/Linux 示例
# CLAUDE_CODE_PATH=/usr/local/bin/claude

# OpenCode CLI 路径
# OPENCODE_PATH=opencode

# Codex CLI 路径
# CODEX_PATH=codex

# ── Desktop ─────────────────────────────────
# VITE_EDGE_URL=http://127.0.0.1:3210
# VITE_HUB_URL=http://127.0.0.1:4210
