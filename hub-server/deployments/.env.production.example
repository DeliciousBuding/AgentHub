# AgentHub Hub Server — 生产环境变量模板 (hk2)
# 复制为 .env.production 并填入真实值
# cp .env.production.example .env.production

# ── 数据库（独立 PostgreSQL 实例，不与 AIhub 共用）──
AGENTHUB_DB_HOST=postgres
AGENTHUB_DB_PORT=5432
AGENTHUB_DB_USER=agenthub
AGENTHUB_DB_PASSWORD=<生成强密码>
AGENTHUB_DB_NAME=agenthub

# ── Redis（独立 Redis 实例，不与 AIhub 共用）───────
AGENTHUB_REDIS_HOST=redis
AGENTHUB_REDIS_PORT=6379
AGENTHUB_REDIS_PASSWORD=<生成强密码>
AGENTHUB_REDIS_DB=0
AGENTHUB_REDIS_POOL_SIZE=100
AGENTHUB_REDIS_MIN_IDLE_CONNS=10

# ── JWT 认证 ─────────────────────────────────────
AGENTHUB_JWT_SECRET=<生成至少32字符的随机密钥>
AGENTHUB_JWT_ACCESS_TTL=15m
AGENTHUB_JWT_REFRESH_TTL=720h

# ── 服务配置 ─────────────────────────────────────
AGENTHUB_ENV=production
AGENTHUB_SERVER_PORT=8080
AGENTHUB_SERVER_LOG_LEVEL=info
AGENTHUB_SERVER_ADMIN_PORT=6060
AGENTHUB_UPLOAD_DIR=./uploads
AGENTHUB_UPLOAD_MAX_SIZE=10485760

# ── PPROF 管理认证（生产必须设置）─────────────────
AGENTHUB_PPROF_USER=admin
AGENTHUB_PPROF_PASS=<生成强密码>

# ── CORS ─────────────────────────────────────────
AGENTHUB_CORS_ORIGINS=https://hub.vectorcontrol.tech
